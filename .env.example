# Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Vercel Cron secret
CRON_SECRET=your_cron_secret_here

# WORC API auth token (server-only)
WORC_P_AUTH=your_worc_token_here

# Resend (email magic links + notifications)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=careers.ky <noreply@careers.ky>

# LinkedIn OAuth (Sign In with LinkedIn using OpenID Connect)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Base URL for links in emails
NEXT_PUBLIC_BASE_URL=https://careers.ky

# Admin dashboard: must match signed-in user email (candidate or employer). Unset in production = admin disabled.
# Also receives employer verification notifications.
# ADMIN_EMAIL=you@example.com
